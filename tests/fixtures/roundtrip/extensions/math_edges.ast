Document
  Paragraph
    Text "Let "
    Math "x" dollars=1
    Text " and "
    Math "y = z + 2" dollars=2
    Text " be values."
  Paragraph
    Text "This is not math: 2000$."
    SoftBreak
    Text "And neither is this $ 4 $."
    SoftBreak
    Text "Or this $4"
    SoftBreak
    Text "$."
  Paragraph
    Text "The cost is between $10 and 30$."
